PORT=3001
NODE_ENV=development

# Telegram bot token from BotFather. Required only if REQUIRE_TELEGRAM_AUTH=true.
BOT_TOKEN=
REQUIRE_TELEGRAM_AUTH=false
TRUSTED_TELEGRAM_USER_IDS=

# Google Sheets storage. If these values are empty, the app uses local JSON storage.
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_SHEET_NAME=PC Builds

# Variant 1: service account fields
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Variant 2: path to service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# Used only by scripts/set-telegram-menu.mjs
WEB_APP_URL=
WEB_APP_BUTTON_TEXT=Сборки ПК
